# Runtime config for docker-compose. Edit and `docker compose up -d --no-deps app`
# to apply without rebuilding the image.

# Postgres
POSTGRES_DB=wallet
POSTGRES_USER=wallet
POSTGRES_PASSWORD=walletpass
POSTGRES_PORT=5432

# Wallet service
APP_PORT=8080
SERVER_PORT=8080

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/wallet
SPRING_DATASOURCE_USERNAME=wallet
SPRING_DATASOURCE_PASSWORD=walletpass

DB_POOL_MAX_SIZE=50
DB_POOL_MIN_IDLE=5
DB_POOL_CONNECTION_TIMEOUT_MS=30000

# Optimistic-lock retry
WALLET_RETRY_MAX_ATTEMPTS=50
WALLET_RETRY_INITIAL_DELAY_MS=10
WALLET_RETRY_MAX_DELAY_MS=200
WALLET_RETRY_MULTIPLIER=2.0

LIQUIBASE_ENABLED=true
WALLET_CORS_ALLOWED_ORIGINS=*
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO

# JVM
JAVA_OPTS=-Xms256m -Xmx512m
